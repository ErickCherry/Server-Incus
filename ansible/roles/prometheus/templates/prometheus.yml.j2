global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts-lab.yml

scrape_configs:
{% for job in prometheus_scrape_targets %}
  - job_name: {{ job.job_name }}
    static_configs:
      - targets:
{% for t in job.targets %}
          - {{ t }}
{% endfor %}
{% if job.metrics_path is defined %}
    metrics_path: {{ job.metrics_path }}
{% endif %}
{% endfor %}
